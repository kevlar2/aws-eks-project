# ==============================================================================
# Example Environment Configuration
# ==============================================================================
# Copy this file to dev.tfvars / prod.tfvars and fill in your values.
# Do NOT commit the actual tfvars files — they are gitignored.

aws_region         = "eu-west-2"
environment        = "Dev" # Dev, Stage, or Prod
project_name       = "2048-eks-project"
cluster_name       = "2048-eks-cluster"
kubernetes_version = "1.34"
node-group-name    = "2048-eks-node-group"
instance_type      = "t3.medium"
vpc_cidr           = "10.0.0.0/16"
az_count           = 2
route53_zone_id    = "ZXXXXXXXXXXXXXXXXX"

# EKS cluster admin access — IAM principal ARNs to grant AmazonEKSClusterAdminPolicy
cluster_admin_arns = [
  "arn:aws:iam::123456789012:user/your-iam-user",
]
